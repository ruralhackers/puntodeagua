generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String  @map("user_id")
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String @id @default(cuid())
  sessionToken String @unique

  expires DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roles         Json      @default("[]")
  
  // Community relationship (optional for SUPER_ADMIN)
  community     Community? @relation(fields: [communityId], references: [id])
  communityId   String?    @map("community_id")
  
  accounts      Account[]
  sessions      Session[]
  files         File[]    // Relación con archivos subidos por el usuario

  @@index([communityId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id   String @id @default(cuid())
  name String

  communities Community[]
}

model Community {
  id   String @id @default(cuid())
  name String

  plan   Plan   @relation(fields: [planId], references: [id])
  planId String @map("plan_id")

  users       User[]
  waterPoints WaterPoint[]
  waterZones  WaterZone[]

  @@index([planId])
}

model WaterZone {
  id   String @id @default(cuid())
  name String

  community   Community @relation(fields: [communityId], references: [id])
  communityId String    @map("community_id")

  analysis Analysis[]
  issue Issue[]
  waterMeters WaterMeter[]

  @@index([communityId])
}

model WaterPoint {
  id       String @id @default(cuid())
  name     String
  location String

  description String @default("") @db.Text
  
  fixedPopulation    Int @default(0) @map("fixed_population")
  floatingPopulation Int @default(0) @map("floating_population")

  community   Community @relation(fields: [communityId], references: [id])
  communityId String    @map("community_id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  waterMeters WaterMeter[]

  @@index([communityId])
}

model Holder {
  id   String @id @default(cuid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  waterMeters WaterMeter[]
}

model WaterMeter {
  id String @id @default(cuid())
  name String

  holder   Holder @relation(fields: [holderId], references: [id])
  holderId String @map("holder_id")

  waterPoint   WaterPoint @relation(fields: [waterPointId], references: [id], onDelete: Cascade)
  waterPointId String     @map("water_point_id")

  waterZone   WaterZone @relation(fields: [waterZoneId], references: [id])
  waterZoneId String    @map("water_zone_id")

  measurementUnit String

  images String[] @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  waterMeterReadings WaterMeterReading[]

  @@index([holderId])
  @@index([waterPointId])
  @@index([waterZoneId])
}

model WaterMeterReading {
  id String @id @default(cuid())

  waterMeter   WaterMeter @relation(fields: [waterMeterId], references: [id], onDelete: Cascade)
  waterMeterId String     @map("water_meter_id")

  reading           Decimal @db.Decimal(10,3)
  normalizedReading Decimal @db.Decimal(10,3)
  readingDate       DateTime
  notes             String?

  files File[] @relation("WaterMeterReadingFiles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([waterMeterId])
}

model File {
  id           String   @id @default(cuid())
  filename     String   // Nombre único del archivo
  originalName String   // Nombre original del usuario
  mimeType     String
  size         Int
  url          String   // URL pública
  bucket       String
  key          String   // Clave en R2
  
  entityType   String   // Tipo de entidad (ej: 'water-meter-reading')
  entityId     String   // ID de la entidad
  
  uploadedBy   String   // ID del usuario que subió
  user         User     @relation(fields: [uploadedBy], references: [id])
  
  // Relaciones con entidades que pueden tener archivos
  waterMeterReadings WaterMeterReading[] @relation("WaterMeterReadingFiles")
  
  createdAt    DateTime @default(now())
  
  @@index([entityType, entityId])
  @@index([uploadedBy])
}

model Issue {
  id String @id @default(cuid())

  waterZone   WaterZone @relation(fields: [waterZoneId], references: [id], onDelete: Cascade)
  waterZoneId String    @map("water_zone_id")

  title        String
  description  String?
  reporterName String

  status  String
  startAt DateTime
  endAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analysis {
  id String @id @default(cuid())

  waterZone   WaterZone @relation(fields: [waterZoneId], references: [id], onDelete: Cascade)
  waterZoneId String    @map("water_zone_id")

  analysisType String
  analyst      String
  analyzedAt   DateTime

  ph          String?
  turbidity   String?
  chlorine    String?
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([waterZoneId])
}
